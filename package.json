{
  "name": "claude-multiple-dashboard",
  "version": "0.2.1",
  "description": "Monitor multiple Claude Code sessions in parallel — real-time dashboard with idle time tracking",
  "type": "module",
  "bin": {
    "claude-dash": "dist/bin/claude-dash.js"
  },
  "files": [
    "dist/",
    "public/",
    "hooks/"
  ],
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "postbuild": "node -e \"const fs=require('fs'); const p='dist/bin/claude-dash.js'; const c=fs.readFileSync(p,'utf8'); if(!c.startsWith('#!')) fs.writeFileSync(p,'#!/usr/bin/env node\\n'+c); fs.chmodSync(p,'755');\"",
    "start": "node dist/src/server.js",
    "dash": "tsx bin/claude-dash.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hey00507/claude-multiple-dashboard.git"
  },
  "keywords": [
    "claude",
    "claude-code",
    "dashboard",
    "monitoring",
    "multi-session",
    "hooks",
    "cli"
  ],
  "author": "hey00507",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/hey00507/claude-multiple-dashboard/issues"
  },
  "homepage": "https://github.com/hey00507/claude-multiple-dashboard#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@fastify/static": "^9.0.0",
    "commander": "^14.0.3",
    "fastify": "^5.8.2",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
